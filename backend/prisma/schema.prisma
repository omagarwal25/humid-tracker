generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Reading {
  id                 Int      @id @default(autoincrement())
  mac                String
  temperature        Float
  humidity           Float
  outdoorTemperature Float?
  outdoorHumidity    Float?
  createdAt          DateTime @default(now())
}
